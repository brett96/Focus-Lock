<?xml version="1.0" encoding="UTF-8"?>
<!--
  Focus Lock Windows Installer
  UpgradeCode: A7B3C5D8-F2E1-4A6F-9B2E-C8D34F5E6A1B  (permanent — never change)

  Pre-requisite: run build/build.ps1 before dotnet build on this project.
  That script publishes all three executables to publish/FocusLock/ and
  isolates FocusLock.Service.exe into publish/service-exe/ so it can be
  wired up with ServiceInstall/ServiceControl without conflicting with the
  AppFiles ComponentGroup glob below.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:netfx="http://wixtoolset.org/schemas/v4/wxs/netfx">

  <Package Name="Focus Lock"
           Version="$(FocusLockAssemblyVersion)"
           Manufacturer="Focus Lock"
           UpgradeCode="A7B3C5D8-F2E1-4A6F-9B2E-C8D34F5E6A1B"
           Scope="perMachine">

    <SummaryInformation Description="Focus Lock Setup — Self parental control for Windows" />
    <MediaTemplate EmbedCab="yes" />

    <!--
      In-place major upgrade: same UpgradeCode + higher Package/@Version removes the
      previous MSI (including stopping/removing FocusLockService) before installing
      new files. Does NOT install a second copy side-by-side.
      Schedule=afterInstallValidate (WiX default): fully uninstall old product first.
    -->
    <MajorUpgrade Schedule="afterInstallValidate"
                  DowngradeErrorMessage="A newer version of Focus Lock is already installed. Please uninstall it first."
                  AllowSameVersionUpgrades="no"
                  IgnoreRemoveFailure="no"
                  MigrateFeatures="yes" />

    <!-- Windows 10 1809+ (build 17763) or Windows 11 — matches app target and .NET 9 desktop support. -->
    <Property Id="WINDOWSBUILD" Secure="yes">
      <RegistrySearch Id="WindowsBuildNumber"
                      Root="HKLM"
                      Key="SOFTWARE\Microsoft\Windows NT\CurrentVersion"
                      Name="CurrentBuildNumber"
                      Type="raw" />
    </Property>
    <Launch Condition="Installed OR WINDOWSBUILD &gt;= 17763"
            Message="Focus Lock requires Windows 10 version 1809 (build 17763) or later, or Windows 11." />

    <!-- .NET 9 Desktop Runtime (x64) — uses hostfxr; reliable on Windows 10 (folder-only checks are not). -->
    <netfx:DotNetCompatibilityCheck Id="DotNet9DesktopCheck"
                                   Property="DOTNET9DESKTOPCHECK"
                                   RuntimeType="desktop"
                                   Platform="x64"
                                   Version="9.0.0"
                                   RollForward="major" />
    <Launch Condition="Installed OR DOTNET9DESKTOPCHECK = &quot;0&quot;"
            Message="Focus Lock requires the .NET Desktop Runtime (x64), version 9.0 or newer.&#13;&#10;Download it from https://dotnet.microsoft.com/download/dotnet/9.0 (or a later major version) and run this installer again." />

    <!-- ── All publish output EXCEPT FocusLock.Service.exe ──────────────────── -->
    <!--
      WiX v5: <Files> inside <ComponentGroup> uses glob patterns.
      The service exe is NOT in publish\FocusLock\ (moved by build.ps1 to
      publish\service-exe\) so there is no duplicate-file conflict with the
      ServiceExeComponent below.
    -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="..\..\publish\FocusLock\**\*" />
    </ComponentGroup>

    <!-- ── C:\Program Files\FocusLock\ ─────────────────────────────────────── -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="FocusLock">

        <!-- Stable component GUIDs — required for reliable major upgrades across versions. -->
        <Component Id="ServiceExeComponent" Guid="A7B3C5D8-F2E1-4A6F-9B2E-C8D34F5E6A01">
          <File Id="ServiceExe" Name="FocusLock.Service.exe"
                Source="..\..\publish\service-exe\FocusLock.Service.exe" KeyPath="yes" />

          <ServiceInstall Id="FocusLockServiceInstall"
                         Name="FocusLockService"
                         DisplayName="Focus Lock Service"
                         Description="Manages Focus Lock sessions, bedtimes, and enforces app and website blocking."
                         Type="ownProcess"
                         Start="auto"
                         ErrorControl="normal"
                         Account="LocalSystem"
                         Interactive="no"
                         Vital="yes" />

          <!-- Stop before file replace on upgrade; remove service only on full uninstall. -->
          <ServiceControl Id="FocusLockServiceControl"
                         Name="FocusLockService"
                         Start="install"
                         Stop="both"
                         Remove="uninstall"
                         Wait="yes" />

          <!--
            util:ServiceConfig configures failure/restart actions.
            The native WiX ServiceConfig does NOT support failure action attributes;
            use WixToolset.Util.wixext for this.
          -->
          <util:ServiceConfig
            ServiceName="FocusLockService"
            FirstFailureActionType="restart"
            SecondFailureActionType="restart"
            ThirdFailureActionType="restart"
            RestartServiceDelayInSeconds="30"
            ResetPeriodInDays="1" />
        </Component>

        <!-- Watchdog: demand-start; SessionProtectionManager starts it during active sessions. -->
        <Component Id="WatchdogExeComponent" Guid="A7B3C5D8-F2E1-4A6F-9B2E-C8D34F5E6A06">
          <File Id="WatchdogExe" Name="FocusLock.Watchdog.exe"
                Source="..\..\publish\watchdog-exe\FocusLock.Watchdog.exe" KeyPath="yes" />

          <ServiceInstall Id="FocusLockWatchdogInstall"
                         Name="FocusLockWatchdog"
                         DisplayName="Focus Lock Watchdog"
                         Description="Restarts Focus Lock Service during strict-mode sessions if it is stopped."
                         Type="ownProcess"
                         Start="demand"
                         ErrorControl="normal"
                         Account="LocalSystem"
                         Interactive="no"
                         Vital="yes" />

          <ServiceControl Id="FocusLockWatchdogControl"
                         Name="FocusLockWatchdog"
                         Stop="both"
                         Remove="uninstall"
                         Wait="yes" />

          <util:ServiceConfig
            ServiceName="FocusLockWatchdog"
            FirstFailureActionType="restart"
            SecondFailureActionType="restart"
            ThirdFailureActionType="restart"
            RestartServiceDelayInSeconds="15"
            ResetPeriodInDays="1" />
        </Component>

        <!-- Allow the service to start in Windows Safe Mode (Minimal). -->
        <Component Id="SafeBootRegistry" Guid="A7B3C5D8-F2E1-4A6F-9B2E-C8D34F5E6A02">
          <RegistryKey Root="HKLM"
                      Key="SYSTEM\CurrentControlSet\Control\SafeBoot\Minimal\FocusLockService">
            <RegistryValue Type="string" Value="Service" KeyPath="yes" />
          </RegistryKey>
        </Component>

        <Component Id="WatchdogSafeBootRegistry" Guid="A7B3C5D8-F2E1-4A6F-9B2E-C8D34F5E6A07">
          <RegistryKey Root="HKLM"
                      Key="SYSTEM\CurrentControlSet\Control\SafeBoot\Minimal\FocusLockWatchdog">
            <RegistryValue Type="string" Value="Service" KeyPath="yes" />
          </RegistryKey>
        </Component>

        <!-- Windows Event Log source so the service can write structured logs. -->
        <Component Id="EventLogSource" Guid="A7B3C5D8-F2E1-4A6F-9B2E-C8D34F5E6A03">
          <RegistryKey Root="HKLM"
                      Key="SYSTEM\CurrentControlSet\Services\EventLog\Application\FocusLock">
            <RegistryValue Type="string" Name="EventMessageFile"
                          Value="[INSTALLFOLDER]FocusLock.Service.exe" KeyPath="yes" />
            <RegistryValue Type="integer" Name="TypesSupported" Value="7" />
          </RegistryKey>
        </Component>

        <Component Id="WatchdogEventLogSource" Guid="A7B3C5D8-F2E1-4A6F-9B2E-C8D34F5E6A08">
          <RegistryKey Root="HKLM"
                      Key="SYSTEM\CurrentControlSet\Services\EventLog\Application\FocusLockWatchdog">
            <RegistryValue Type="string" Name="EventMessageFile"
                          Value="[INSTALLFOLDER]FocusLock.Watchdog.exe" KeyPath="yes" />
            <RegistryValue Type="integer" Name="TypesSupported" Value="7" />
          </RegistryKey>
        </Component>

      </Directory>
    </StandardDirectory>

    <!-- ── C:\ProgramData\FocusLock\ ───────────────────────────────────────── -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="FocusLockDataDir" Name="FocusLock">
        <Component Id="DataDirectory" Guid="A7B3C5D8-F2E1-4A6F-9B2E-C8D34F5E6A04">
          <CreateFolder />
          <RegistryValue Root="HKCU" Key="Software\FocusLock\Install"
                        Name="DataDir" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- ── Start Menu shortcut ──────────────────────────────────────────────── -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="FocusLockMenuDir" Name="Focus Lock">
        <Component Id="StartMenuShortcut" Guid="A7B3C5D8-F2E1-4A6F-9B2E-C8D34F5E6A05">
          <Shortcut Id="AppShortcut" Name="Focus Lock"
                    Description="Stay focused. Get it done."
                    Target="[INSTALLFOLDER]FocusLock.UI.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveFocusLockMenuDir" Directory="FocusLockMenuDir" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\FocusLock\Install"
                        Name="Shortcut" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!--
      Release service DACLs via sc.exe (WixQuietExec). No embedded .NET EXE — those often fail with
      "a program required for this install could not be run". Return=ignore if a service is missing.
      Two short commands (MSI CustomAction Target column max 255 chars).
    -->
    <?define UnlockMainSdset = "&quot;[SystemFolder]sc.exe&quot; sdset FocusLockService D:(A;;GA;;;SY)(A;;GA;;;BA)" ?>
    <?define UnlockWatchSdset = "&quot;[SystemFolder]sc.exe&quot; sdset FocusLockWatchdog D:(A;;GA;;;SY)(A;;GA;;;BA)" ?>

    <CustomAction Id="SetUnlockMainCmd" Property="WixQuietExecCmdLine" Value="$(var.UnlockMainSdset)" />
    <CustomAction Id="SetUnlockWatchCmd" Property="WixQuietExecCmdLine" Value="$(var.UnlockWatchSdset)" />
    <CustomAction Id="RunUnlockMainSc"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
                  DllEntry="WixQuietExec"
                  Execute="immediate"
                  Impersonate="no"
                  Return="ignore" />
    <CustomAction Id="RunUnlockWatchSc"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
                  DllEntry="WixQuietExec"
                  Execute="immediate"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Before RemoveExistingProducts (upgrade) or that sequence slot (uninstall). -->
    <InstallExecuteSequence>
      <Custom Action="SetUnlockMainCmd" Before="RunUnlockMainSc" Condition="Installed" />
      <Custom Action="RunUnlockMainSc" Before="SetUnlockWatchCmd" Condition="Installed" />
      <Custom Action="SetUnlockWatchCmd" Before="RunUnlockWatchSc" Condition="Installed" />
      <Custom Action="RunUnlockWatchSc" Before="RemoveExistingProducts" Condition="Installed" />
    </InstallExecuteSequence>

    <!-- ── Feature tree ─────────────────────────────────────────────────────── -->

    <Feature Id="ProductFeature" Title="Focus Lock" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ServiceExeComponent" />
      <ComponentRef Id="WatchdogExeComponent" />
      <ComponentRef Id="SafeBootRegistry" />
      <ComponentRef Id="WatchdogSafeBootRegistry" />
      <ComponentRef Id="EventLogSource" />
      <ComponentRef Id="WatchdogEventLogSource" />
      <ComponentRef Id="DataDirectory" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>
</Wix>

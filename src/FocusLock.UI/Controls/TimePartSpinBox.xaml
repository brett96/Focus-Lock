<UserControl x:Class="FocusLock.UI.Controls.TimePartSpinBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MinWidth="44">
  <UserControl.Resources>
    <Style x:Key="SpinArrowButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#A6ADC8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0,2"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="9"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                <Setter Property="Foreground" Value="#CDD6F4"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#585B70"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="SpinTextBox" TargetType="TextBox">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="CaretBrush" Value="#CDD6F4"/>
      <Setter Property="SelectionBrush" Value="#89B4FA"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="Padding" Value="4,4"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Style.Triggers>
        <Trigger Property="IsFocused" Value="True">
          <Setter Property="Background" Value="#45475A"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <Border BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Background="#313244">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Button Grid.Row="0" Content="▲" Style="{StaticResource SpinArrowButton}"
              Click="Increment_Click" ToolTip="Increase"/>
      <TextBox Grid.Row="1" x:Name="PartTextBox"
               Style="{StaticResource SpinTextBox}"
               MaxLength="2"
               PreviewTextInput="PartTextBox_PreviewTextInput"
               LostFocus="PartTextBox_LostFocus"/>
      <Button Grid.Row="2" Content="▼" Style="{StaticResource SpinArrowButton}"
              Click="Decrement_Click" ToolTip="Decrease"/>
    </Grid>
  </Border>
</UserControl>

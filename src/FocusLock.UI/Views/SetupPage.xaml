<Page x:Class="FocusLock.UI.Views.SetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:FocusLock.UI.Controls"
      mc:Ignorable="d"
      Background="#1E1E2E"
      d:DesignHeight="600" d:DesignWidth="900">

    <Page.Resources>
        <!-- Makes the text inside DatePicker readable on the dark background -->
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CaretBrush" Value="#CDD6F4"/>
            <Setter Property="SelectionBrush" Value="#89B4FA"/>
        </Style>

        <Style x:Key="TimeInputBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#CDD6F4"/>
            <Setter Property="SelectionBrush" Value="#89B4FA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- AM/PM toggle button -->
        <Style x:Key="AmPmButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="12,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#383A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dropdown toggle button for app picker -->
        <Style x:Key="DropdownToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#585B70"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="12,9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="▾" Foreground="#6C7086"
                                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA"/>
                                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Day-of-week pill toggle used in Screen Time schedule picker -->
        <Style x:Key="DayToggle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bd" Background="#3D3F55" BorderBrush="#585B70" BorderThickness="1"
                                CornerRadius="6" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E3A5F"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Checkbox style for the app list (dark-theme) -->
        <Style x:Key="AppCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bd" Background="Transparent" Padding="10,7" CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="Box" Width="16" Height="16" CornerRadius="3"
                                        Background="Transparent" BorderBrush="#585B70" BorderThickness="1.5"
                                        Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="Tick" Text="✓" Foreground="#89B4FA" FontSize="11"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box"  Property="Background"   Value="#1E3A5F"/>
                                <Setter TargetName="Box"  Property="BorderBrush"  Value="#89B4FA"/>
                                <Setter TargetName="Tick" Property="Visibility"   Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D3F55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="40">
            <TextBlock Text="New Focus Session" FontSize="28" FontWeight="Bold"
                       Foreground="#CDD6F4" Margin="0,0,0,24"/>

            <!-- Mode selection -->
            <TextBlock Text="MODE" FontSize="11" FontWeight="Bold" Foreground="#6C7086" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <RadioButton Content="Regular" IsChecked="{Binding IsRegularMode}"
                             Foreground="#CDD6F4" Margin="0,0,20,0" FontSize="14"/>
                <RadioButton Content="Strict (cannot end early)" IsChecked="{Binding IsStrictMode}"
                             Foreground="#F38BA8" FontSize="14"/>
            </StackPanel>

            <!-- Strict consent -->
            <Border Background="#313244" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                    Visibility="{Binding IsStrictMode, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="⚠ Strict Mode Warning" FontWeight="Bold" Foreground="#F38BA8"
                               FontSize="14" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#A6ADC8" FontSize="13">
                        Strict mode prevents the Focus Lock service from being stopped for the duration of the session.
                        Blocked apps and the hosts file will be locked at the system level.
                        You will NOT be able to end the session early. No exceptions.
                    </TextBlock>
                    <CheckBox Content="I understand — I cannot unlock this session early."
                              IsChecked="{Binding StrictConsentGiven}"
                              Foreground="#CDD6F4" Margin="0,12,0,0" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Deadline -->
            <TextBlock Text="END DATE &amp; TIME" FontSize="11" FontWeight="Bold"
                       Foreground="#6C7086" Margin="0,0,0,8"/>
            <Border BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Padding="1"
                    Background="#313244" HorizontalAlignment="Left" Margin="0,0,0,10">
                <DatePicker SelectedDate="{Binding DeadlineDate}"
                            DisplayDateStart="{Binding TodayDate, Mode=OneWay}"
                            DisplayDateEnd="{Binding MaxDeadlineDate, Mode=OneWay}"
                            Background="Transparent" Foreground="#CDD6F4"
                            BorderThickness="0" FontSize="14" Padding="6,5" MinWidth="195"/>
            </Border>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24" VerticalAlignment="Center">
                <controls:TimePartSpinBox Value="{Binding DeadlineHour, UpdateSourceTrigger=PropertyChanged}"
                                          Part="{x:Static controls:TimePartKind.Hour12}" Width="52"/>
                <TextBlock Text=":" Foreground="#CDD6F4" FontSize="20" VerticalAlignment="Center" Margin="6,0"/>
                <controls:TimePartSpinBox Value="{Binding DeadlineMinute, UpdateSourceTrigger=PropertyChanged}"
                                          Part="{x:Static controls:TimePartKind.Minute}" Width="52"/>
                <Border Background="#313244" BorderBrush="#585B70" BorderThickness="1" CornerRadius="6"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="AM" IsChecked="{Binding IsAmPmAm, Mode=TwoWay}"
                                     GroupName="AmPm" Style="{StaticResource AmPmButton}"/>
                        <RadioButton Content="PM" IsChecked="{Binding IsAmPmPm, Mode=TwoWay}"
                                     GroupName="AmPm" Style="{StaticResource AmPmButton}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Blocked apps -->
            <TextBlock Text="BLOCKED APPLICATIONS" FontSize="11" FontWeight="Bold"
                       Foreground="#6C7086" Margin="0,0,0,4"/>
            <TextBlock Text="Optional if you set screen time limits below."
                       FontSize="12" Foreground="#6C7086" Margin="0,0,0,8"/>

            <!-- Dropdown toggle + popup -->
            <Grid HorizontalAlignment="Left" Margin="0,0,0,8">
                <ToggleButton x:Name="AppDropdownBtn"
                              Content="{Binding AppDropdownLabel}"
                              Style="{StaticResource DropdownToggleButton}"
                              MinWidth="280"/>

                <Popup x:Name="AppPopup"
                       PlacementTarget="{Binding ElementName=AppDropdownBtn}"
                       Placement="Bottom"
                       IsOpen="{Binding IsChecked, ElementName=AppDropdownBtn}"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       Closed="AppPopup_Closed">
                    <Border Background="#313244" BorderBrush="#585B70" BorderThickness="1"
                            CornerRadius="6" Width="320">
                        <StackPanel>
                            <!-- Search -->
                            <Border BorderBrush="#585B70" BorderThickness="0,0,0,1" Padding="8">
                                <TextBox Text="{Binding AppSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#1E1E2E" Foreground="#CDD6F4"
                                         CaretBrush="#CDD6F4" SelectionBrush="#89B4FA"
                                         BorderThickness="1" BorderBrush="#585B70"
                                         FontSize="13" Padding="8,6"/>
                            </Border>

                            <!-- App list -->
                            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto"
                                          Background="Transparent">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding FilteredApps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Content="{Binding DisplayName}"
                                                          Style="{DynamicResource AppCheckBox}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Loading installed applications..."
                                               Visibility="{Binding IsLoadingApps, Converter={StaticResource BoolToVisibility}}"
                                               Foreground="#6C7086" Margin="16,12" FontSize="13"/>
                                    <TextBlock Text="No applications found."
                                               Visibility="{Binding HasNoFilteredApps, Converter={StaticResource BoolToVisibility}}"
                                               Foreground="#6C7086" Margin="16,12" FontSize="13"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Browse for unlisted app -->
                            <Border BorderBrush="#585B70" BorderThickness="0,1,0,0" Padding="8">
                                <Button Content="Browse for unlisted app..."
                                        Command="{Binding BrowseForAppCommand}"
                                        Background="Transparent" Foreground="#89B4FA"
                                        BorderThickness="0" Cursor="Hand"
                                        FontSize="13" HorizontalAlignment="Left"
                                        Padding="2,4"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <!-- Selected apps list -->
            <ItemsControl ItemsSource="{Binding BlockedApps}" Margin="0,0,0,24">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#313244" CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                            <Grid>
                                <TextBlock Text="{Binding DisplayName}" Foreground="#CDD6F4" FontSize="13" VerticalAlignment="Center"/>
                                <Button Content="✕" HorizontalAlignment="Right"
                                        Command="{Binding DataContext.RemoveAppCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" Foreground="#F38BA8"
                                        BorderThickness="0" Cursor="Hand" FontSize="14"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Blocked sites -->
            <TextBlock Text="BLOCKED WEBSITES" FontSize="11" FontWeight="Bold"
                       Foreground="#6C7086" Margin="0,0,0,4"/>
            <TextBlock Text="Optional if you set screen time limits below."
                       FontSize="12" Foreground="#6C7086" Margin="0,0,0,8"/>

            <TextBlock Text="Block by category" FontSize="13" Foreground="#A6ADC8" Margin="0,0,0,8"/>
            <Border Background="#313244" CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                <ItemsControl ItemsSource="{Binding WebsiteCategories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Content="{Binding Label}"
                                      Style="{StaticResource AppCheckBox}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <ItemsControl ItemsSource="{Binding BlockedSites}" Margin="0,0,0,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#313244" CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                            <Grid>
                                <TextBlock Text="{Binding Domain}" Foreground="#CDD6F4" FontSize="13" VerticalAlignment="Center"/>
                                <Button Content="✕" HorizontalAlignment="Right"
                                        Command="{Binding DataContext.RemoveSiteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" Foreground="#F38BA8"
                                        BorderThickness="0" Cursor="Hand" FontSize="14"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBox Text="{Binding NewSiteDomain, UpdateSourceTrigger=PropertyChanged}"
                         Width="240" Background="#313244" Foreground="#CDD6F4"
                         BorderThickness="0" FontSize="14" Padding="10,8"/>
                <Button Content="Add" Command="{Binding AddSiteCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- ── SCREEN TIME LIMITS ──────────────────────────────────────────── -->
            <TextBlock Text="DAILY SCREEN TIME LIMITS" FontSize="11" FontWeight="Bold"
                       Foreground="#6C7086" Margin="0,0,0,8"/>

            <ItemsControl ItemsSource="{Binding StDailyLimits}" Margin="0,0,0,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#313244" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Foreground="#CDD6F4" FontSize="13" FontWeight="SemiBold">
                                        <Run Text="{Binding LimitSummary, Mode=OneWay}"/>
                                        <Run Text=" per day"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ScheduleSummary, Mode=OneWay}"
                                               Foreground="#6C7086" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Edit" Command="{Binding EditCommand}"
                                            Background="Transparent" Foreground="#89B4FA"
                                            BorderThickness="0" Cursor="Hand" FontSize="12"
                                            Padding="8,0" Margin="0,0,4,0"/>
                                    <Button Content="✕" Command="{Binding RemoveCommand}"
                                            Background="Transparent" Foreground="#F38BA8"
                                            BorderThickness="0" Cursor="Hand" FontSize="14"
                                            Padding="8,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="+ Add Daily Limit"
                    Command="{Binding StShowAddDailyLimitCommand}"
                    Visibility="{Binding StIsNotAddingDaily, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Left" Margin="0,0,0,8"/>

            <Border Background="#313244" CornerRadius="8" Padding="18,16" Margin="0,0,0,16"
                    Visibility="{Binding StIsAddingDailyLimit, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{Binding StDailyLimitFormTitle}" FontSize="15" FontWeight="SemiBold"
                               Foreground="#CDD6F4" Margin="0,0,0,14"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                        <TextBlock Text="Limit to" Foreground="#A6ADC8" FontSize="13" VerticalAlignment="Center"/>
                        <Border BorderBrush="#585B70" BorderThickness="1" CornerRadius="6"
                                Background="#1E1E2E" Margin="10,0,4,0">
                            <TextBox Text="{Binding StDraftDailyLimitHours, UpdateSourceTrigger=PropertyChanged}"
                                     Width="44" Style="{StaticResource TimeInputBox}"/>
                        </Border>
                        <TextBlock Text="h" Foreground="#A6ADC8" FontSize="13" VerticalAlignment="Center" Margin="2,0,10,0"/>
                        <Border BorderBrush="#585B70" BorderThickness="1" CornerRadius="6"
                                Background="#1E1E2E" Margin="0,0,4,0">
                            <TextBox Text="{Binding StDraftDailyLimitMin, UpdateSourceTrigger=PropertyChanged}"
                                     Width="44" Style="{StaticResource TimeInputBox}"/>
                        </Border>
                        <TextBlock Text="min" Foreground="#A6ADC8" FontSize="13"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Minimum 5 minutes. Schedules cannot overlap other daily limits."
                               Foreground="#6C7086" FontSize="12" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox IsChecked="{Binding StDailyDraftMon}" Content="Mon" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                        <CheckBox IsChecked="{Binding StDailyDraftTue}" Content="Tue" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                        <CheckBox IsChecked="{Binding StDailyDraftWed}" Content="Wed" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                        <CheckBox IsChecked="{Binding StDailyDraftThu}" Content="Thu" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                        <CheckBox IsChecked="{Binding StDailyDraftFri}" Content="Fri" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                        <CheckBox IsChecked="{Binding StDailyDraftSat}" Content="Sat" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                        <CheckBox IsChecked="{Binding StDailyDraftSun}" Content="Sun" Style="{StaticResource DayToggle}"/>
                    </StackPanel>

                    <CheckBox Content="Limit to a time range on selected days"
                              IsChecked="{Binding StDraftDailyUseCustomSchedule}"
                              Foreground="#CDD6F4" FontSize="13" Margin="0,0,0,10"/>

                    <StackPanel Visibility="{Binding StShowDailyDraftSchedulePicker, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="From" Foreground="#A6ADC8" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <controls:TimePartSpinBox Value="{Binding StDailyDraftStartHour, UpdateSourceTrigger=PropertyChanged}"
                                                      Part="{x:Static controls:TimePartKind.Hour12}" Width="44"/>
                            <TextBlock Text=":" Foreground="#CDD6F4" FontSize="16" VerticalAlignment="Center" Margin="4,0"/>
                            <controls:TimePartSpinBox Value="{Binding StDailyDraftStartMinute, UpdateSourceTrigger=PropertyChanged}"
                                                      Part="{x:Static controls:TimePartKind.Minute}" Width="44"/>
                            <Border Background="#313244" BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Margin="6,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="AM" IsChecked="{Binding StDailyDraftStartIsAm, Mode=TwoWay}" GroupName="StDL_S" Style="{StaticResource AmPmButton}"/>
                                    <RadioButton Content="PM" IsChecked="{Binding StDailyDraftStartIsPm, Mode=TwoWay}" GroupName="StDL_S" Style="{StaticResource AmPmButton}"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="to" Foreground="#A6ADC8" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <controls:TimePartSpinBox Value="{Binding StDailyDraftEndHour, UpdateSourceTrigger=PropertyChanged}"
                                                      Part="{x:Static controls:TimePartKind.Hour12}" Width="44"/>
                            <TextBlock Text=":" Foreground="#CDD6F4" FontSize="16" VerticalAlignment="Center" Margin="4,0"/>
                            <controls:TimePartSpinBox Value="{Binding StDailyDraftEndMinute, UpdateSourceTrigger=PropertyChanged}"
                                                      Part="{x:Static controls:TimePartKind.Minute}" Width="44"/>
                            <Border Background="#313244" BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Margin="6,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="AM" IsChecked="{Binding StDailyDraftEndIsAm, Mode=TwoWay}" GroupName="StDL_E" Style="{StaticResource AmPmButton}"/>
                                    <RadioButton Content="PM" IsChecked="{Binding StDailyDraftEndIsPm, Mode=TwoWay}" GroupName="StDL_E" Style="{StaticResource AmPmButton}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{Binding StDailyLimitAddError}" Foreground="#F38BA8" FontSize="12"
                               Margin="0,0,0,8" TextWrapping="Wrap"
                               Visibility="{Binding HasStDailyLimitAddError, Converter={StaticResource BoolToVisibility}}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="{Binding StDailyLimitFormButtonText}" Command="{Binding StAddDailyLimitCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                        <Button Content="Cancel" Command="{Binding StCancelAddDailyCommand}"
                                Style="{StaticResource DangerButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- APP TIME LIMITS -->
            <TextBlock Text="APP TIME LIMITS" FontSize="11" FontWeight="Bold"
                       Foreground="#6C7086" Margin="0,0,0,8"/>

            <ItemsControl ItemsSource="{Binding StAppLimits}" Margin="0,0,0,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#313244" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="#CDD6F4"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Foreground="#6C7086" FontSize="12" Margin="0,2,0,0">
                                        <Run Text="{Binding LimitSummary, Mode=OneWay}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding ScheduleSummary, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Edit" Command="{Binding EditCommand}"
                                            Background="Transparent" Foreground="#89B4FA"
                                            BorderThickness="0" Cursor="Hand" FontSize="12"
                                            Padding="8,0" Margin="0,0,4,0"/>
                                    <Button Content="✕" Command="{Binding RemoveCommand}"
                                            Background="Transparent" Foreground="#F38BA8"
                                            BorderThickness="0" Cursor="Hand" FontSize="14"
                                            Padding="8,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="+ Add App Limit"
                    Command="{Binding StShowAddAppLimitCommand}"
                    Visibility="{Binding StIsNotAdding, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Left" Margin="0,0,0,16"/>

            <!-- ADD APP LIMIT FORM -->
            <Border Background="#313244" CornerRadius="8" Padding="18,16" Margin="0,0,0,16"
                    Visibility="{Binding StIsAddingAppLimit, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{Binding StAppLimitFormTitle}" FontSize="15" FontWeight="SemiBold"
                               Foreground="#CDD6F4" Margin="0,0,0,14"/>

                    <TextBlock Text="APPLICATION" FontSize="11" FontWeight="Bold"
                               Foreground="#6C7086" Margin="0,0,0,6"/>
                    <Grid HorizontalAlignment="Left" Margin="0,0,0,14">
                        <ToggleButton x:Name="StDraftAppBtn"
                                      IsChecked="{Binding StIsDraftAppPopupOpen, Mode=TwoWay}"
                                      Style="{StaticResource DropdownToggleButton}" MinWidth="260">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Select application..."/>
                                        <Setter Property="Foreground" Value="#6C7086"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StHasDraftExe}" Value="True">
                                                <Setter Property="Text" Value="{Binding StDraftDisplayName}"/>
                                                <Setter Property="Foreground" Value="#CDD6F4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </ToggleButton>

                        <Popup x:Name="StDraftAppPopup"
                               PlacementTarget="{Binding ElementName=StDraftAppBtn}"
                               Placement="Bottom"
                               IsOpen="{Binding StIsDraftAppPopupOpen, Mode=TwoWay}"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               Closed="StAppPopup_Closed">
                            <Border Background="#313244" BorderBrush="#585B70" BorderThickness="1"
                                    CornerRadius="6" Width="300">
                                <StackPanel>
                                    <Border BorderBrush="#585B70" BorderThickness="0,0,0,1" Padding="8">
                                        <TextBox Text="{Binding StDraftAppSearch, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="#1E1E2E" Foreground="#CDD6F4"
                                                 CaretBrush="#CDD6F4" SelectionBrush="#89B4FA"
                                                 BorderThickness="1" BorderBrush="#585B70"
                                                 FontSize="13" Padding="8,6"/>
                                    </Border>
                                    <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <ItemsControl ItemsSource="{Binding StFilteredDraftApps}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border x:Name="StRow" Padding="12,7" Cursor="Hand">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                    Command="{Binding DataContext.StSelectDraftAppCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                    CommandParameter="{Binding}"/>
                                                            </Border.InputBindings>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="#CDD6F4" FontSize="13"/>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#3D3F55"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="Loading..."
                                                       Visibility="{Binding IsLoadingApps, Converter={StaticResource BoolToVisibility}}"
                                                       Foreground="#6C7086" Margin="14,10" FontSize="13"/>
                                            <TextBlock Text="No applications found."
                                                       Visibility="{Binding StHasNoDraftApps, Converter={StaticResource BoolToVisibility}}"
                                                       Foreground="#6C7086" Margin="14,10" FontSize="13"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                    <Border BorderBrush="#585B70" BorderThickness="0,1,0,0" Padding="8">
                                        <Button Content="Browse for unlisted app..."
                                                Command="{Binding StBrowseDraftAppCommand}"
                                                Background="Transparent" Foreground="#89B4FA"
                                                BorderThickness="0" Cursor="Hand"
                                                FontSize="13" HorizontalAlignment="Left" Padding="2,4"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <TextBlock Text="LIMIT TYPE" FontSize="11" FontWeight="Bold"
                               Foreground="#6C7086" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <RadioButton Content="Daily Total" GroupName="StDraftLimitType"
                                     IsChecked="{Binding StIsDailyTotalDraft, Mode=TwoWay}"
                                     Foreground="#CDD6F4" FontSize="13" Margin="0,0,20,0" Cursor="Hand"/>
                        <RadioButton Content="Interval (X min every Y min)" GroupName="StDraftLimitType"
                                     IsChecked="{Binding StIsIntervalDraft, Mode=TwoWay}"
                                     Foreground="#CDD6F4" FontSize="13" Cursor="Hand"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,14"
                                Visibility="{Binding StIsDailyTotalDraft, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Max" Foreground="#A6ADC8" FontSize="13" VerticalAlignment="Center"/>
                        <Border BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Background="#1E1E2E" Margin="8,0,4,0">
                            <TextBox Text="{Binding StDraftLimitHours, UpdateSourceTrigger=PropertyChanged}" Width="40" Style="{StaticResource TimeInputBox}"/>
                        </Border>
                        <TextBlock Text="h" Foreground="#A6ADC8" FontSize="13" VerticalAlignment="Center" Margin="2,0,8,0"/>
                        <Border BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Background="#1E1E2E" Margin="0,0,4,0">
                            <TextBox Text="{Binding StDraftLimitMin, UpdateSourceTrigger=PropertyChanged}" Width="40" Style="{StaticResource TimeInputBox}"/>
                        </Border>
                        <TextBlock Text="min per day" Foreground="#A6ADC8" FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,14"
                                Visibility="{Binding StIsIntervalDraft, Converter={StaticResource BoolToVisibility}}">
                        <Border BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Background="#1E1E2E">
                            <TextBox Text="{Binding StDraftIntervalLimit, UpdateSourceTrigger=PropertyChanged}" Width="52" Style="{StaticResource TimeInputBox}"/>
                        </Border>
                        <TextBlock Text="min every" Foreground="#A6ADC8" FontSize="13" VerticalAlignment="Center" Margin="8,0"/>
                        <Border BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Background="#1E1E2E">
                            <TextBox Text="{Binding StDraftIntervalPeriod, UpdateSourceTrigger=PropertyChanged}" Width="60" Style="{StaticResource TimeInputBox}"/>
                        </Border>
                        <TextBlock Text="min" Foreground="#A6ADC8" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <CheckBox Content="Use a custom schedule for this app"
                              IsChecked="{Binding StDraftUseCustomSchedule}"
                              Foreground="#A6ADC8" FontSize="13" Margin="0,0,0,10"/>

                    <StackPanel Visibility="{Binding StShowDraftSchedulePicker, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox IsChecked="{Binding StDraftMon}" Content="Mon" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                            <CheckBox IsChecked="{Binding StDraftTue}" Content="Tue" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                            <CheckBox IsChecked="{Binding StDraftWed}" Content="Wed" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                            <CheckBox IsChecked="{Binding StDraftThu}" Content="Thu" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                            <CheckBox IsChecked="{Binding StDraftFri}" Content="Fri" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                            <CheckBox IsChecked="{Binding StDraftSat}" Content="Sat" Style="{StaticResource DayToggle}" Margin="0,0,6,0"/>
                            <CheckBox IsChecked="{Binding StDraftSun}" Content="Sun" Style="{StaticResource DayToggle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="From" Foreground="#A6ADC8" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <controls:TimePartSpinBox Value="{Binding StDraftStartHour, UpdateSourceTrigger=PropertyChanged}"
                                                      Part="{x:Static controls:TimePartKind.Hour12}" Width="40"/>
                            <TextBlock Text=":" Foreground="#CDD6F4" FontSize="16" VerticalAlignment="Center" Margin="4,0"/>
                            <controls:TimePartSpinBox Value="{Binding StDraftStartMinute, UpdateSourceTrigger=PropertyChanged}"
                                                      Part="{x:Static controls:TimePartKind.Minute}" Width="40"/>
                            <Border Background="#313244" BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Margin="6,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="AM" IsChecked="{Binding StDraftStartIsAm, Mode=TwoWay}" GroupName="StDS_AmPm" Style="{StaticResource AmPmButton}"/>
                                    <RadioButton Content="PM" IsChecked="{Binding StDraftStartIsPm, Mode=TwoWay}" GroupName="StDS_AmPm" Style="{StaticResource AmPmButton}"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="to" Foreground="#A6ADC8" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <controls:TimePartSpinBox Value="{Binding StDraftEndHour, UpdateSourceTrigger=PropertyChanged}"
                                                      Part="{x:Static controls:TimePartKind.Hour12}" Width="40"/>
                            <TextBlock Text=":" Foreground="#CDD6F4" FontSize="16" VerticalAlignment="Center" Margin="4,0"/>
                            <controls:TimePartSpinBox Value="{Binding StDraftEndMinute, UpdateSourceTrigger=PropertyChanged}"
                                                      Part="{x:Static controls:TimePartKind.Minute}" Width="40"/>
                            <Border Background="#313244" BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Margin="6,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="AM" IsChecked="{Binding StDraftEndIsAm, Mode=TwoWay}" GroupName="StDE_AmPm" Style="{StaticResource AmPmButton}"/>
                                    <RadioButton Content="PM" IsChecked="{Binding StDraftEndIsPm, Mode=TwoWay}" GroupName="StDE_AmPm" Style="{StaticResource AmPmButton}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{Binding StAppLimitAddError}" Foreground="#F38BA8" FontSize="12"
                               Margin="0,0,0,8" TextWrapping="Wrap"
                               Visibility="{Binding HasStAppLimitAddError, Converter={StaticResource BoolToVisibility}}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="{Binding StAppLimitFormButtonText}" Command="{Binding StAddAppLimitCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                        <Button Content="Cancel" Command="{Binding StCancelAddCommand}"
                                Style="{StaticResource DangerButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F38BA8" FontSize="13"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                       Margin="0,0,0,16" TextWrapping="Wrap"/>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Start Session" Command="{Binding StartSessionCommand}"
                        Style="{StaticResource PrimaryButton}" IsEnabled="{Binding IsNotBusy}"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"
                        Style="{StaticResource DangerButton}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

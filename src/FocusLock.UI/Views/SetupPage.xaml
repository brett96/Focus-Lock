<Page x:Class="FocusLock.UI.Views.SetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#1E1E2E"
      d:DesignHeight="600" d:DesignWidth="900">

    <Page.Resources>
        <!-- Makes the text inside DatePicker readable on the dark background -->
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CaretBrush" Value="#CDD6F4"/>
            <Setter Property="SelectionBrush" Value="#89B4FA"/>
        </Style>

        <Style x:Key="TimeInputBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#CDD6F4"/>
            <Setter Property="SelectionBrush" Value="#89B4FA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- AM/PM toggle button — looks like the website entry pills -->
        <Style x:Key="AmPmButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="12,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#383A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="40">
            <TextBlock Text="New Focus Session" FontSize="28" FontWeight="Bold"
                       Foreground="#CDD6F4" Margin="0,0,0,24"/>

            <!-- Mode selection -->
            <TextBlock Text="MODE" FontSize="11" FontWeight="Bold" Foreground="#6C7086" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <RadioButton Content="Regular" IsChecked="{Binding IsRegularMode}"
                             Foreground="#CDD6F4" Margin="0,0,20,0" FontSize="14"/>
                <RadioButton Content="Strict (cannot end early)" IsChecked="{Binding IsStrictMode}"
                             Foreground="#F38BA8" FontSize="14"/>
            </StackPanel>

            <!-- Strict consent -->
            <Border Background="#313244" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                    Visibility="{Binding IsStrictMode, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="⚠ Strict Mode Warning" FontWeight="Bold" Foreground="#F38BA8"
                               FontSize="14" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#A6ADC8" FontSize="13">
                        Strict mode prevents the Focus Lock service from being stopped for the duration of the session.
                        Blocked apps and the hosts file will be locked at the system level.
                        You will NOT be able to end the session early. No exceptions.
                    </TextBlock>
                    <CheckBox Content="I understand — I cannot unlock this session early."
                              IsChecked="{Binding StrictConsentGiven}"
                              Foreground="#CDD6F4" Margin="0,12,0,0" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Deadline -->
            <TextBlock Text="END DATE &amp; TIME" FontSize="11" FontWeight="Bold"
                       Foreground="#6C7086" Margin="0,0,0,8"/>
            <Border BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Padding="1"
                    Background="#313244" HorizontalAlignment="Left" Margin="0,0,0,10">
                <DatePicker SelectedDate="{Binding DeadlineDate}"
                            Background="Transparent" Foreground="#CDD6F4"
                            BorderThickness="0" FontSize="14" Padding="6,5" MinWidth="195"/>
            </Border>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24" VerticalAlignment="Center">
                <Border BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Background="#313244">
                    <TextBox Text="{Binding DeadlineHour, UpdateSourceTrigger=PropertyChanged}"
                             Width="52" Style="{StaticResource TimeInputBox}"/>
                </Border>
                <TextBlock Text=":" Foreground="#CDD6F4" FontSize="20" VerticalAlignment="Center" Margin="6,0"/>
                <Border BorderBrush="#585B70" BorderThickness="1" CornerRadius="6" Background="#313244">
                    <TextBox Text="{Binding DeadlineMinute, UpdateSourceTrigger=PropertyChanged}"
                             Width="52" Style="{StaticResource TimeInputBox}"/>
                </Border>
                <Border Background="#313244" BorderBrush="#585B70" BorderThickness="1" CornerRadius="6"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="AM" IsChecked="{Binding IsAmPmAm, Mode=TwoWay}"
                                     GroupName="AmPm" Style="{StaticResource AmPmButton}"/>
                        <RadioButton Content="PM" IsChecked="{Binding IsAmPmPm, Mode=TwoWay}"
                                     GroupName="AmPm" Style="{StaticResource AmPmButton}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Blocked apps -->
            <TextBlock Text="BLOCKED APPLICATIONS" FontSize="11" FontWeight="Bold"
                       Foreground="#6C7086" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding BlockedApps}" Margin="0,0,0,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#313244" CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                            <Grid>
                                <TextBlock Text="{Binding DisplayName}" Foreground="#CDD6F4" FontSize="13" VerticalAlignment="Center"/>
                                <Button Content="✕" HorizontalAlignment="Right"
                                        Command="{Binding DataContext.RemoveAppCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" Foreground="#F38BA8"
                                        BorderThickness="0" Cursor="Hand" FontSize="14"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="+ Add Application" Command="{Binding BrowseForAppCommand}"
                    Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,0,0,24"/>

            <!-- Blocked sites -->
            <TextBlock Text="BLOCKED WEBSITES" FontSize="11" FontWeight="Bold"
                       Foreground="#6C7086" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding BlockedSites}" Margin="0,0,0,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#313244" CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                            <Grid>
                                <TextBlock Text="{Binding Domain}" Foreground="#CDD6F4" FontSize="13" VerticalAlignment="Center"/>
                                <Button Content="✕" HorizontalAlignment="Right"
                                        Command="{Binding DataContext.RemoveSiteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" Foreground="#F38BA8"
                                        BorderThickness="0" Cursor="Hand" FontSize="14"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBox Text="{Binding NewSiteDomain, UpdateSourceTrigger=PropertyChanged}"
                         Width="240" Background="#313244" Foreground="#CDD6F4"
                         BorderThickness="0" FontSize="14" Padding="10,8"/>
                <Button Content="Add" Command="{Binding AddSiteCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F38BA8" FontSize="13"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                       Margin="0,0,0,16" TextWrapping="Wrap"/>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Start Session" Command="{Binding StartSessionCommand}"
                        Style="{StaticResource PrimaryButton}" IsEnabled="{Binding IsNotBusy}"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"
                        Style="{StaticResource DangerButton}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

<Page x:Class="FocusLock.UI.Views.ActiveSessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#1E1E2E"
      d:DesignHeight="600" d:DesignWidth="900">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Focus Session Active" FontSize="28" FontWeight="Bold"
                   Foreground="#A6E3A1" Margin="0,0,0,24"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <TextBlock Text="{Binding TimeRemaining}" FontSize="64" FontWeight="Bold"
                           Foreground="#CDD6F4" HorizontalAlignment="Center" FontFamily="Consolas"/>
                <TextBlock Text="{Binding DeadlineText, StringFormat='Ends {0}'}"
                           FontSize="14" Foreground="#6C7086" HorizontalAlignment="Center" Margin="0,8,0,32"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- Blocked apps -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="BLOCKED APPS" FontSize="11" FontWeight="Bold"
                                   Foreground="#6C7086" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding BlockedApps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#313244" CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding DisplayName}" Foreground="#CDD6F4" FontSize="13"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Blocked sites -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="BLOCKED SITES" FontSize="11" FontWeight="Bold"
                                   Foreground="#6C7086" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding BlockedSites}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#313244" CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Domain}" Foreground="#CDD6F4" FontSize="13"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2">
            <Button Content="End Session Early"
                    Command="{Binding EndSessionCommand}"
                    Visibility="{Binding CanEndEarly, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource DangerButton}" HorizontalAlignment="Center"/>
            <TextBlock Text="Strict mode — session is locked until the deadline."
                       Foreground="#F38BA8" FontSize="13" HorizontalAlignment="Center"
                       Visibility="{Binding IsStrictActive, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>
    </Grid>
</Page>

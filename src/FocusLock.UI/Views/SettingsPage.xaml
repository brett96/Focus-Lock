<Page x:Class="FocusLock.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#1E1E2E"
      d:DesignHeight="600" d:DesignWidth="900">

    <StackPanel Margin="40">
        <TextBlock Text="Settings" FontSize="28" FontWeight="Bold"
                   Foreground="#CDD6F4" Margin="0,0,0,32"/>

        <!-- Start with Windows -->
        <Border Background="#313244" CornerRadius="8" Padding="18,14" Margin="0,0,0,8">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Start with Windows" Foreground="#CDD6F4" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="Focus Lock will launch automatically when you log in."
                               Foreground="#6C7086" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
                <CheckBox IsChecked="{Binding StartWithWindows}"
                          HorizontalAlignment="Right" VerticalAlignment="Center"
                          Foreground="#CDD6F4"/>
            </Grid>
        </Border>

        <!-- Minimize to tray note -->
        <Border Background="#313244" CornerRadius="8" Padding="18,14" Margin="0,0,0,32">
            <StackPanel>
                <TextBlock Text="Minimize to Tray" Foreground="#CDD6F4" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock TextWrapping="Wrap" Foreground="#6C7086" FontSize="12" Margin="0,4,0,0">
                    Closing the window hides Focus Lock to the system tray. Right-click the tray icon to exit.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Emergency Reset -->
        <Border Background="#313244" CornerRadius="8" Padding="18,14" Margin="0,0,0,32">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Emergency Reset" Foreground="#F38BA8" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#6C7086" FontSize="12" Margin="0,4,0,0">
                        Forcefully clears all app blocks and website restrictions. Use this if a session ended
                        but apps or sites are still blocked. Not available during an active session.
                    </TextBlock>
                    <TextBlock Text="{Binding ResetMessage}" TextWrapping="Wrap"
                               Foreground="#A6ADC8" FontSize="12" Margin="0,8,0,0"
                               Visibility="{Binding HasResetMessage, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Reset"
                        Command="{Binding ForceResetCommand}"
                        Style="{StaticResource DangerButton}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Button Content="← Back" Command="{Binding BackCommand}"
                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
    </StackPanel>
</Page>
